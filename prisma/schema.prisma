generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  timezone      String   @default("UTC")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  eventTypes          EventType[]
  availabilityRules   AvailabilityRule[]
  bookings            Booking[]
  calendarIntegrations CalendarIntegration[]
  webhooks            Webhook[]
  emailTemplates      EmailTemplate[]
}

model EventType {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  duration    Int      // in minutes
  slug        String   // URL suffix
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([userId, slug])
}

model AvailabilityRule {
  id              String   @id @default(uuid())
  userId          String
  dayOfWeek       Int      // 0=Sunday, 6=Saturday
  startTime       String   // HH:mm format
  endTime         String   // HH:mm format
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvailabilitySettings {
  id                    String @id @default(uuid())
  userId                String @unique
  minAdvanceHours       Int    @default(24)    // minimum hours in advance
  maxAdvanceDays        Int    @default(60)    // maximum days in advance
  bufferMinutes         Int    @default(0)     // buffer between bookings
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Booking {
  id              String        @id @default(uuid())
  eventTypeId     String
  userId          String        // event owner
  guestName       String
  guestEmail      String
  guestNotes      String?
  startTime       DateTime
  endTime         DateTime
  status          BookingStatus @default(CONFIRMED)
  timezone        String
  cancelToken     String        @unique @default(uuid())
  calendarEventId String?       // external calendar event ID for sync
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model CalendarIntegration {
  id           String          @id @default(uuid())
  userId       String
  provider     CalendarProvider
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  calendarId   String?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

enum CalendarProvider {
  GOOGLE
  APPLE
}

model Webhook {
  id        String   @id @default(uuid())
  userId    String
  url       String
  events    String[] // e.g., ["booking.created", "booking.cancelled"]
  secret    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        String   @id @default(uuid())
  userId    String
  type      EmailTemplateType
  subject   String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

enum EmailTemplateType {
  BOOKING_CONFIRMATION_HOST
  BOOKING_CONFIRMATION_GUEST
  BOOKING_CANCELLATION_HOST
  BOOKING_CANCELLATION_GUEST
  BOOKING_REMINDER
}
